[database]
server = YOUR_SERVER_NAME
database = DN_Live
username = your_sql_login
password = your_password
table = V_CHARACTERISTICS
encrypt = yes
trust_server_certificate = yes

[logging]
log_dir = logs
max_bytes = 10485760
backup_count = 5

[paths]
; DLA FLIS Electronic Reading Room page -- the importer scrapes this page
; to find the Characteristics.zip download link automatically.
download_url = https://www.dla.mil/Information-Operations/FLIS-Data-Electronic-Reading-Room/
work_dir = work
